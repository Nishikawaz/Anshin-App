#!/bin/sh
# Anshin — pre-commit hook
# Instalar: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

echo "🔍 Anshin pre-commit checks..."

# ── 1. MONTOS: nunca Double/Float para dinero ──────────────────────────────
MONEY_VIOLATIONS=$(git diff --cached --name-only | grep "\.kt$" | xargs grep -l \
  -E "(price|amount|balance|total|sum|cost|valor|monto|saldo).*:\s*(Double|Float)" \
  2>/dev/null || true)

if [ -n "$MONEY_VIOLATIONS" ]; then
  echo "${RED}❌ DINERO EN DOUBLE/FLOAT — usar Long (centavos):${NC}"
  echo "$MONEY_VIOLATIONS"
  ERRORS=$((ERRORS + 1))
fi

# ── 2. LOG con datos financieros ───────────────────────────────────────────
LOG_VIOLATIONS=$(git diff --cached --name-only | grep "\.kt$" | xargs grep -n \
  -E "Log\.[deiw]\(.*\b(amount|balance|account|token|password|monto|saldo|cuenta)\b" \
  2>/dev/null || true)

if [ -n "$LOG_VIOLATIONS" ]; then
  echo "${RED}❌ LOG CON DATOS FINANCIEROS — eliminar antes de commit:${NC}"
  echo "$LOG_VIOLATIONS"
  ERRORS=$((ERRORS + 1))
fi

# ── 3. android.* en domain/ ───────────────────────────────────────────────
DOMAIN_VIOLATIONS=$(git diff --cached --name-only | grep "domain/.*\.kt$" | xargs grep -n \
  "^import android\." 2>/dev/null || true)

if [ -n "$DOMAIN_VIOLATIONS" ]; then
  echo "${RED}❌ IMPORT ANDROID EN DOMAIN — el dominio no debe conocer el SDK:${NC}"
  echo "$DOMAIN_VIOLATIONS"
  ERRORS=$((ERRORS + 1))
fi

# ── 4. Idioma hardcodeado en STT ──────────────────────────────────────────
STT_VIOLATIONS=$(git diff --cached --name-only | grep "\.kt$" | xargs grep -n \
  -E 'EXTRA_LANGUAGE.*"(es-PY|es-ES|pt-BR|en-US)"' 2>/dev/null || true)

if [ -n "$STT_VIOLATIONS" ]; then
  echo "${RED}❌ IDIOMA STT HARDCODEADO — leer desde SpeechConfig/RemoteConfig:${NC}"
  echo "$STT_VIOLATIONS"
  ERRORS=$((ERRORS + 1))
fi

# ── 5. fallbackToDestructiveMigration en Room ─────────────────────────────
MIGRATION_VIOLATIONS=$(git diff --cached --name-only | grep "\.kt$" | xargs grep -n \
  "fallbackToDestructiveMigration" 2>/dev/null || true)

if [ -n "$MIGRATION_VIOLATIONS" ]; then
  echo "${RED}❌ fallbackToDestructiveMigration DETECTADO — agregar migración explícita:${NC}"
  echo "$MIGRATION_VIOLATIONS"
  ERRORS=$((ERRORS + 1))
fi

# ── 6. SharedPreferences sin cifrar ──────────────────────────────────────
PREFS_VIOLATIONS=$(git diff --cached --name-only | grep "\.kt$" | xargs grep -n \
  "getSharedPreferences\|PreferenceManager\.getDefault" 2>/dev/null || true)

if [ -n "$PREFS_VIOLATIONS" ]; then
  echo "${YELLOW}⚠️  SharedPreferences sin cifrar — ¿deberías usar EncryptedSharedPreferences?${NC}"
  echo "$PREFS_VIOLATIONS"
  WARNINGS=$((WARNINGS + 1))
fi

# ── 7. isConfirmed ausente en entidades de OCR/Audio ─────────────────────
OCR_AUDIO_FILES=$(git diff --cached --name-only | grep -E "(ocr|audio|speech|OcrResult|SpeechTransaction).*\.kt$" || true)
if [ -n "$OCR_AUDIO_FILES" ]; then
  CONFIRMED_CHECK=$(echo "$OCR_AUDIO_FILES" | xargs grep -L "isConfirmed" 2>/dev/null || true)
  if [ -n "$CONFIRMED_CHECK" ]; then
    echo "${YELLOW}⚠️  Archivos OCR/Audio sin isConfirmed — verificar flujo de confirmación:${NC}"
    echo "$CONFIRMED_CHECK"
    WARNINGS=$((WARNINGS + 1))
  fi
fi

# ── 8. Ktlint ─────────────────────────────────────────────────────────────
if command -v ktlint >/dev/null 2>&1; then
  STAGED_KT=$(git diff --cached --name-only | grep "\.kt$" || true)
  if [ -n "$STAGED_KT" ]; then
    KTLINT_RESULT=$(echo "$STAGED_KT" | xargs ktlint 2>&1 || true)
    if [ -n "$KTLINT_RESULT" ]; then
      echo "${YELLOW}⚠️  KTLINT — corregir formato:${NC}"
      echo "$KTLINT_RESULT"
      WARNINGS=$((WARNINGS + 1))
    fi
  fi
fi

# ── Resultado final ───────────────────────────────────────────────────────
echo ""
if [ $ERRORS -gt 0 ]; then
  echo "${RED}❌ $ERRORS error(s) encontrado(s) — commit bloqueado.${NC}"
  echo "   Corregí los errores y volvé a hacer commit."
  exit 1
fi

if [ $WARNINGS -gt 0 ]; then
  echo "${YELLOW}⚠️  $WARNINGS advertencia(s) — revisá antes de pushear.${NC}"
fi

echo "${GREEN}✅ Anshin checks OK — commit permitido.${NC}"
exit 0
