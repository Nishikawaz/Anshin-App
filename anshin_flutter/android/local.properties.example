# Copy this file to `android/local.properties` if needed.
# Keep your real credentials out of git.

# Android SDK path (generated by Flutter/Android Studio)
sdk.dir=C:\\Users\\<user>\\AppData\\Local\\Android\\Sdk

# Flutter SDK path (generated by Flutter)
flutter.sdk=C:\\tools\\flutter

# Google Sign-In: Web OAuth Client ID
google.serverClientId=TU_WEB_CLIENT_ID.apps.googleusercontent.com
