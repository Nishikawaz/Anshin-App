#!/usr/bin/env bash
set -euo pipefail

COMMIT_MSG_FILE="$1"
FIRST_LINE="$(head -n 1 "$COMMIT_MSG_FILE" | tr -d '\r')"

if [ -z "$FIRST_LINE" ]; then
  echo "commit-msg: empty commit message is not allowed."
  exit 1
fi

if echo "$FIRST_LINE" | grep -Eq '^(Merge|Revert) '; then
  exit 0
fi

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .{1,72}$'

if ! echo "$FIRST_LINE" | grep -Eq "$PATTERN"; then
  echo "commit-msg: invalid format."
  echo "Use Conventional Commits, for example:"
  echo "  feat(auth): add google sign-in recovery"
  echo "  fix(ocr): improve amount extraction"
  exit 1
fi

